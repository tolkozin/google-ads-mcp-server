# Copy to `.env` (gitignored). The server loads this automatically on startup.

# --- Credentials ---
# Absolute path to your google-ads.yaml. Defaults to ~/google-ads.yaml if unset.
GOOGLE_ADS_CREDENTIALS=/absolute/path/to/google-ads.yaml

# --- Safety flags (enforced from Phase 2 onward; reads ignore them) ---
# Master switch for ALL write/mutate tools. Keep false until you intend to make changes.
ADS_MCP_ENABLE_MUTATIONS=false

# Comma-separated allowlist of customer ids (no dashes). Empty = allow any accessible account.
# Operations outside this list are rejected.
GOOGLE_ADS_ALLOWED_CUSTOMER_IDS=

# Hard ceiling for any single daily budget / bid you can set without override=true.
GOOGLE_ADS_MAX_DAILY_BUDGET_USD=100

# When true, mutate tools default to validate_only (dry-run) unless explicitly overridden.
GOOGLE_ADS_DEFAULT_VALIDATE_ONLY=true

# Path for the JSONL audit log of real (applied) changes.
GOOGLE_ADS_AUDIT_LOG=./google-ads.audit.jsonl

# --- Daily analysis automation (daily_analysis.py) ---
# Customer id to analyze in the daily report (no dashes).
ADS_ANALYSIS_ACCOUNT=1234567890
# Optional login-customer-id header override (defaults to ADS_ANALYSIS_ACCOUNT).
ADS_ANALYSIS_LOGIN_CID=
