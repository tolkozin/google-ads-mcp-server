# Copy into Streamlit Cloud → App settings → Secrets (or .streamlit/secrets.toml locally).
# Never commit the real file — .streamlit/secrets.toml is gitignored.

[ads]
account = "1234567890"          # customer id to analyze, no dashes

[google_ads]
developer_token   = "YOUR_DEVELOPER_TOKEN"
client_id         = "YOUR_OAUTH_CLIENT_ID.apps.googleusercontent.com"
client_secret     = "YOUR_OAUTH_CLIENT_SECRET"
refresh_token     = "YOUR_REFRESH_TOKEN"
login_customer_id = "1234567890"  # manager (MCC) id, optional

# Account-specific vocabulary and copy (mirrors config.json, which is gitignored
# and therefore absent in cloud deployments). Without this the app falls back to
# the neutral English placeholders in config.example.json.
[config]
brand = "Acme"
geo_target_constant = "geoTargetConstants/2840"
language_constant  = "languageConstants/1000"
keyword_seeds = ["buy product online"]
intent_tokens = ["buy", "app", "where"]
junk_tokens   = ["free", "jobs", "tutorial"]

[config.creative_bank]
headlines    = ["Get started in minutes", "Simple and secure"]
descriptions = ["Get started in minutes and manage everything from one secure app."]
